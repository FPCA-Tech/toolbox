# Database Connection Settings
DB_HOST=
DB_NAME=
DB_USER=
DB_PASS=

# YouTube API key and Playlist ID for the sermons.  The API key must have access to the YouTube Data API v3.
YT_API_KEY=
YT_PLAYLIST=

# Minimum seconds between sync.php runs (used as a guard, not a trigger —
# sync.php is meant to be run on a schedule, e.g. hourly via cron).
CACHE_TIME=3600